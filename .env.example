# OpenAGI environment configuration.
# Copy to .env or .openagi/.env and fill in. The daemon loads both.

# --- Model provider ---
# Per project rule: default to GPT-5 family.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
# Optional override:
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Twilio (SMS) ---
# Inbound: configure your Twilio phone number to POST messages to
#   https://<your-public-host>/channels/twilio/webhook
# Outbound (proactive sends, scheduled prompts that ping by SMS) needs:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Where the agent should text you proactively (your phone):
DEFAULT_SMS_TARGET=

# --- Telegram ---
# Create a bot via BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=
# Set to "1" to long-poll Telegram on startup. Leave blank if you'll register
# a webhook to /channels/telegram/webhook instead.
TELEGRAM_POLLING=

# --- Daemon ---
HOST=127.0.0.1
PORT=43210
OPENAGI_DATA_DIR=.openagi
# Background ticker (ms). Set to 0 to disable; the runtime.tick() will then
# only run on POST /tick.
OPENAGI_TICKER_MS=10000
